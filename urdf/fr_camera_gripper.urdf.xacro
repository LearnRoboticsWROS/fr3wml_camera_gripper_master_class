  <xacro:property name="mesh_path" value="package://fr3wml_camera_gripper/meshes"/>

  <!-- LINK VIRTUALE WORLD -->


  <!-- JOINT FISSO world → gripper_body -->
  <joint name="world_to_gripper" type="fixed">
    <parent link="wrist3_link"/>
    <child  link="gripper_body"/>
    <origin xyz="0 0 0.098" rpy="0 0 0"/>
  </joint>

  <!-- GRIPPER BODY -->
  <link name="gripper_body">
    <visual>
      <origin xyz="0.052568 0.031349 0.100767" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/gripper2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.052568 0.031349 0.100767" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/gripper2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia
        ixx="0.003" iyy="0.003" izz="0.003"
        ixy="0.0"  ixz="0.0"  iyz="0.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

    <!-- SUCTION CAP  -->
  <link name="suction_cap">
    <visual>
        <origin xyz="-0.021682 0.000886 0.014867" rpy="0 0 0"/>
        <geometry>
        <mesh filename="${mesh_path}/suction_cap.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </visual>
    <collision>
        <origin xyz="-0.021682 0.000886 0.014867" rpy="0 0 0"/>
        <geometry>
        <mesh filename="${mesh_path}/suction_cap.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.1"/>
        <inertia
        ixx="0.001" iyy="0.001" izz="0.001"
        ixy="0.0"  ixz="0.0"  iyz="0.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </inertial>
  </link>

  <!-- JOINT FIx gripper_body → suction cap -->
  <joint name="gripper__suction" type="fixed">
    <parent link="gripper_body"/>
    <child  link="suction_cap"/>
    <origin xyz="0 0 0.037" rpy="0 0 0"/>
  </joint>

  <!-- camera -->


    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>


    <link name="camera_link">
        <inertial>
            <origin xyz="-0.00936000000 -0.00003000000 -0.00273000000" rpy="0 0 0"/>
            <mass value="0.21970000000"/>
            <inertia ixx="0.00000429247" ixy="0.00000000000" ixz="0.00000002565"
                    iyy="0.00000008027" iyz="0.00000000000"
                    izz="0.00000427339"/>
        </inertial>
        <visual>
            <geometry>
                <!-- <box size="0.01 0.03 0.03" /> -->
                <mesh filename="file://${FR}/meshes/kinetic.stl"/>
     
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <mesh filename="file://${FR}/meshes/kinetic.dae"/>
            </geometry>
        </collision>
    </link>

    <!-- frames in the center of the camera -->
    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="0.5 0 1.2" rpy="0 1.57 0" />
    </joint>

    <link name="camera_optical_link"></link>

    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_optical_link"/>
        <origin xyz="0 0 0" rpy="-1.57 0 -1.57" />
    </joint>

    <gazebo reference="camera_link">
        <sensor name="camera" type="depth">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <camera>
            <horizontal_fov>1.089</horizontal_fov>
            <image><format>R8G8B8</format><width>640</width><height>480</height></image>
            <clip><near>0.05</near><far>8</far></clip>
            </camera>
            <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
            <frame_name>camera_optical_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>


</robot>